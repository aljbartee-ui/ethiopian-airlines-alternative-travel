PORT=3000
DATABASE_URL=postgres://user:password@host:port/dbname
ET_PASSWORD=your_et_password_here
ALSAWAN_PASSWORD=your_alsawan_password_here

# On Render you'll set:
# - PORT → 10000 is auto-set by Render, but Express will read process.env.PORT.
# - DATABASE_URL → from Render PostgreSQL.
# - ET_PASSWORD, ALSAWAN_PASSWORD → whatever you agree internally.
